<div id="progress_card" class="bg-zg-surface rounded-xl border border-zg-border p-5 mb-4">
  <div class="flex items-center justify-between mb-2">
    <span class="text-sm font-semibold text-white/80">First week setup</span>
    <span class="text-sm font-bold text-zg-teal">
      <%= completed_count %>/<%= total_count %> done
    </span>
  </div>
  <div class="w-full bg-white/10 rounded-full h-2.5">
    <div class="h-2.5 rounded-full bg-zg-teal"
         style="width: <%= pct %>%; transition: width 0.6s ease"></div>
  </div>
  <div class="flex items-center justify-between mt-2">
    <p class="text-xs <%= pct == 100 ? 'text-zg-teal font-medium' : 'text-white/40' %>">
      <%= pct == 100 ? "✓ You're all set up." : "Your HoD can see your progress." %>
    </p>
    <% if pct < 100 %>
      <p class="text-xs text-white/40">~<%= (total_count - completed_count) * 5 %> min left</p>
    <% end %>
  </div>
</div>
