<% completed_count = @completions.count %>
<% total_count     = @tasks.count %>
<% pct             = total_count > 0 ? (completed_count.to_f / total_count * 100).round : 0 %>
<%# @completions is now task_id => { id:, completed_at: } %>

<div class="mb-6">
  <p class="text-sm text-zg-gray font-medium uppercase tracking-wide mb-1">
    Oakwood Academy · Mathematics
  </p>
  <h1 class="text-2xl font-bold text-gray-900 mb-1">
    Good <%= Time.current.hour < 12 ? "morning" : "afternoon" %>, <%= @teacher.name.split.first %>.
  </h1>
  <p class="text-gray-500 text-sm">
    <% if pct == 100 %>
      You're all set up. Students can now get the most from Zero Gravity.
    <% elsif completed_count > 0 %>
      You're nearly there — keep going.
    <% else %>
      Complete these 5 steps in your first week — about 25 minutes total.
    <% end %>
  </p>
</div>

<div id="split-container" class="flex gap-4 items-start">

  <div id="task-list-panel" style="width:40%; min-width:0; flex-shrink:0;">

    <%= render "progress_card", completed_count: completed_count, total_count: total_count, pct: pct %>

    <div class="space-y-3">
      <% @tasks.each do |task| %>
        <% c = @completions[task.id] %>
        <%= render "task_row",
              task:          task,
              done:          c.present?,
              active:        task.id == @active_task.id,
              completion_id: c&.fetch(:id),
              completed_at:  c&.fetch(:completed_at),
              teacher:       @teacher %>
      <% end %>
    </div>

  </div>

  <turbo-frame id="task_detail"
               src="<%= task_path(@active_task) %>"
               style="flex:1; min-width:0;">
  </turbo-frame>

</div>

<style>
  @keyframes detailFadeIn {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  #task_detail .detail-content {
    animation: detailFadeIn 0.25s ease forwards;
  }
</style>

<script>
  // Task 3 — student report toggle (defined here so it survives Turbo Stream replacement)
  function toggleReport(i) {
    document.getElementById('report-' + i).classList.toggle('hidden')
    document.getElementById('got-it-form').classList.remove('hidden')
  }

  // Task 4 — copy join link then submit completion form
  function copyAndComplete() {
    navigator.clipboard.writeText('join.zerogravity.ai/oak-maths-7b').catch(() => {})
    const btn = document.getElementById('copy-btn')
    btn.textContent = 'Copied ✓'
    btn.disabled = true
    btn.classList.replace('bg-zg-blue', 'bg-zg-green')
    setTimeout(() => document.getElementById('copy-complete-form').requestSubmit(), 800)
  }

  // Event delegation so re-rendered rows keep working
  document.addEventListener('click', function(e) {
    const link = e.target.closest('[data-turbo-frame="task_detail"]')
    if (!link) return
    const clickedRow = link.closest('.task-row')
    if (!clickedRow) return
    document.querySelectorAll('.task-row').forEach(function(row) {
      row.classList.remove('border-zg-blue', 'ring-1', 'ring-zg-blue')
      if (!row.classList.contains('border-green-200')) row.classList.add('border-gray-200')
      const p = row.querySelector('a p')
      if (p) { p.classList.remove('text-zg-blue'); p.classList.add('text-gray-900') }
    })
    clickedRow.classList.remove('border-gray-200')
    clickedRow.classList.add('border-zg-blue', 'ring-1', 'ring-zg-blue')
    const title = clickedRow.querySelector('a p')
    if (title) { title.classList.remove('text-gray-900'); title.classList.add('text-zg-blue') }
  })
</script>
