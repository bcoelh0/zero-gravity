<div class="mb-8">
  <p class="text-sm text-white/50 font-medium uppercase tracking-wide mb-1">
    Oakwood Academy · Head of Department
  </p>
  <h1 class="text-2xl font-bold text-white mb-1">Help your team get set up</h1>
  <p class="text-white/50 text-sm">
    The sooner your teachers complete their first week, the sooner students benefit.
  </p>
</div>

<%# Department aggregate progress bar %>
<% activated   = @teachers.select { |t| t.activation_status == :activated }.count %>
<% in_progress = @teachers.select { |t| t.activation_status == :in_progress }.count %>
<% not_started = @teachers.select { |t| t.activation_status == :not_started }.count %>
<% total_teachers = @teachers.count %>

<div class="bg-zg-surface rounded-xl border border-zg-border p-5 mb-6">
  <div class="flex items-center justify-between mb-3">
    <span class="text-sm font-semibold text-white/80">Department setup</span>
    <span class="text-sm font-bold <%= activated == total_teachers ? 'text-zg-teal' : 'text-zg-teal' %>">
      <%= activated %> of <%= total_teachers %> fully set up
    </span>
  </div>
  <div class="w-full bg-white/10 rounded-full h-3 flex overflow-hidden">
    <div class="h-3 bg-zg-teal transition-all duration-500"
         style="width: <%= total_teachers > 0 ? (activated.to_f / total_teachers * 100).round : 0 %>%"></div>
    <div class="h-3 bg-zg-teal/50 transition-all duration-500"
         style="width: <%= total_teachers > 0 ? (in_progress.to_f / total_teachers * 100).round : 0 %>%"></div>
  </div>
  <div class="flex gap-4 mt-2">
    <span class="text-xs text-white/40 flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-full bg-zg-teal"></span><%= activated %> set up</span>
    <span class="text-xs text-white/40 flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-full bg-zg-teal/50"></span><%= in_progress %> in progress</span>
    <span class="text-xs text-white/40 flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-full bg-white/20"></span><%= not_started %> not started</span>
  </div>
</div>

<%# Teacher table %>
<div class="bg-zg-surface rounded-xl border border-zg-border overflow-hidden">
  <div class="px-5 py-4 border-b border-zg-border flex items-center justify-between">
    <h2 class="font-semibold text-sm text-white/80"><%= @department.name %> department</h2>
    <% not_started_names = @teachers.select { |t| t.activation_status == :not_started }.map { |t| t.name.split.first } %>
    <% if not_started_names.any? %>
      <button onclick="nudgeAll(<%= not_started_names.to_json %>)"
              class="text-xs bg-white/10 text-white/60 font-medium px-3 py-1.5 rounded-lg hover:bg-white/15 transition-colors cursor-pointer">
        Nudge all not-started (<%= not_started_names.count %>)
      </button>
    <% end %>
  </div>
  <table class="w-full text-sm">
    <thead>
      <tr class="text-xs font-medium text-white/30 uppercase tracking-wide bg-white/5 border-b border-zg-border">
        <th class="px-5 py-3 text-left">Teacher</th>
        <th class="px-5 py-3 text-left">Progress</th>
        <th class="px-5 py-3 text-left">Last active</th>
        <th class="px-5 py-3 text-left">Status</th>
        <th class="px-5 py-3 text-left"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-white/5">
      <% @teachers.each do |teacher| %>
        <% done       = teacher.tasks_completed_count %>
        <% total      = @total_tasks %>
        <% pct        = total > 0 ? (done.to_f / total * 100).round : 0 %>
        <% days_idle  = teacher.days_since_login %>
        <% is_idle    = teacher.activation_status != :activated && (days_idle.nil? || days_idle > 3) %>
        <% next_task  = @next_task_by_teacher[teacher.id] %>
        <% completed_task_ids = teacher.teacher_task_completions.map(&:onboarding_task_id).to_set %>
        <tr class="hover:bg-white/5 transition-colors cursor-pointer select-none <%= is_idle ? 'border-l-2 border-l-amber-400' : '' %>"
            onclick="toggleTeacherDetails(<%= teacher.id %>)">
          <td class="px-5 py-4">
            <div class="flex items-center gap-2">
              <svg id="chevron-<%= teacher.id %>" class="w-3.5 h-3.5 text-white/25 transition-transform duration-200 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
              <div>
                <p class="font-medium text-white"><%= teacher.name %></p>
                <p class="text-xs text-white/40"><%= teacher.email %></p>
              </div>
            </div>
          </td>
          <td class="px-5 py-4">
            <div class="flex items-center gap-2">
              <div class="w-24 bg-white/10 rounded-full h-1.5">
                <div class="h-1.5 rounded-full <%= pct == 100 ? 'bg-zg-teal' : pct > 0 ? 'bg-zg-teal' : 'bg-white/20' %>"
                     style="width: <%= pct %>%"></div>
              </div>
              <span class="text-xs text-white/50 whitespace-nowrap"><%= done %>/<%= total %></span>
            </div>
            <% if next_task && teacher.activation_status != :activated %>
              <p class="text-xs text-white/25 mt-1">On step <%= next_task.position %> · <%= next_task.title %></p>
            <% end %>
          </td>
          <td class="px-5 py-4 text-xs">
            <% if teacher.last_login_at.nil? %>
              <span class="text-white/25">Never logged in</span>
            <% elsif days_idle == 0 %>
              <span class="text-white/50">Today</span>
            <% elsif days_idle == 1 %>
              <span class="text-white/50">Yesterday</span>
            <% else %>
              <span class="<%= is_idle ? 'text-amber-400 font-medium' : 'text-white/50' %>">
                <%= days_idle %> days ago<%= is_idle ? " ⚠" : "" %>
              </span>
            <% end %>
          </td>
          <td class="px-5 py-4">
            <% case teacher.activation_status %>
            <% when :activated %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-zg-teal/20 text-zg-teal">✓ Set up</span>
            <% when :in_progress %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-zg-teal/10 text-zg-teal">⬤ In progress</span>
            <% when :not_started %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-amber-400/15 text-amber-400 <%= is_idle ? 'ring-1 ring-amber-400/40' : '' %>">○ Not started</span>
            <% end %>
          </td>
          <td class="px-5 py-4">
            <% unless teacher.activation_status == :activated %>
              <button onclick="event.stopPropagation(); nudgeTeacher(this, '<%= teacher.name.split.first %>')"
                      class="text-xs text-zg-teal font-medium hover:underline whitespace-nowrap nudge-btn"
                      data-name="<%= teacher.name.split.first %>">
                Send a nudge →
              </button>
            <% end %>
          </td>
        </tr>
        <tr id="teacher-details-<%= teacher.id %>" class="hidden bg-white/5">
          <td colspan="5" class="px-5 py-4">
            <div class="flex gap-8 text-sm">
              <div class="flex-1">
                <p class="text-xs font-semibold text-white/40 uppercase tracking-wide mb-2">Teacher info</p>
                <dl class="space-y-1">
                  <% if teacher.subject.present? %>
                    <div class="flex gap-2">
                      <dt class="text-white/40 text-xs w-24 flex-shrink-0">Subject</dt>
                      <dd class="text-white/70 text-xs"><%= teacher.subject %></dd>
                    </div>
                  <% end %>
                  <% if teacher.topic.present? %>
                    <div class="flex gap-2">
                      <dt class="text-white/40 text-xs w-24 flex-shrink-0">Topic</dt>
                      <dd class="text-white/70 text-xs"><%= teacher.topic %></dd>
                    </div>
                  <% end %>
                  <% if teacher.curriculum_level.present? %>
                    <div class="flex gap-2">
                      <dt class="text-white/40 text-xs w-24 flex-shrink-0">Level</dt>
                      <dd class="text-white/70 text-xs"><%= teacher.curriculum_level %></dd>
                    </div>
                  <% end %>
                  <div class="flex gap-2">
                    <dt class="text-white/40 text-xs w-24 flex-shrink-0">Weekly emails</dt>
                    <dd class="text-xs <%= teacher.weekly_email_opted_in ? 'text-zg-teal' : 'text-white/40' %>">
                      <%= teacher.weekly_email_opted_in ? "Opted in" : "Not opted in" %>
                    </dd>
                  </div>
                </dl>
              </div>
              <div class="flex-1">
                <p class="text-xs font-semibold text-white/40 uppercase tracking-wide mb-2">Setup tasks</p>
                <ul class="space-y-1">
                  <% @all_tasks.each do |task| %>
                    <% completed = completed_task_ids.include?(task.id) %>
                    <li class="flex items-start gap-2 text-xs <%= completed ? 'text-white/30' : 'text-white/60' %>">
                      <span class="flex-shrink-0 mt-0.5 <%= completed ? 'text-zg-teal' : 'text-white/25' %>">
                        <%= completed ? "✓" : "○" %>
                      </span>
                      <span class="<%= completed ? 'line-through' : '' %>"><%= task.title %></span>
                    </li>
                  <% end %>
                </ul>
              </div>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div id="nudge-toast" class="hidden fixed bottom-6 right-6 bg-zg-surface border border-zg-border text-white text-sm px-4 py-3 rounded-xl shadow-lg z-50"></div>

<script>
  function toggleTeacherDetails(id) {
    const row = document.getElementById("teacher-details-" + id);
    const chevron = document.getElementById("chevron-" + id);
    const isOpen = !row.classList.contains("hidden");
    row.classList.toggle("hidden", isOpen);
    chevron.style.transform = isOpen ? "" : "rotate(90deg)";
  }

  function nudgeTeacher(btn, name) {
    btn.textContent = "Sent ✓";
    btn.disabled = true;
    btn.classList.replace("text-zg-teal", "text-white/40");
    showToast(`Reminder sent to ${name} ✓`);
  }

  function nudgeAll(names) {
    document.querySelectorAll('.nudge-btn').forEach(btn => {
      btn.textContent = "Sent ✓";
      btn.disabled = true;
      btn.classList.replace("text-zg-teal", "text-white/40");
    });
    const btn = event.currentTarget;
    btn.textContent = "All sent ✓";
    btn.disabled = true;
    showToast(`Reminders sent to ${names.join(", ")} ✓`);
  }

  function showToast(msg) {
    const toast = document.getElementById("nudge-toast");
    toast.textContent = msg;
    toast.classList.remove("hidden");
    setTimeout(() => toast.classList.add("hidden"), 3000);
  }
</script>

<p class="text-xs text-white/30 mt-4 text-center">
  Nudges send a friendly reminder, not a warning.
</p>
