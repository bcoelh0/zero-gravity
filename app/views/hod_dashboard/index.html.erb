<div class="mb-8">
  <p class="text-sm text-zg-gray font-medium uppercase tracking-wide mb-1">
    Oakwood Academy · Head of Department
  </p>
  <h1 class="text-2xl font-bold text-gray-900 mb-1">Help your team get set up</h1>
  <p class="text-gray-500 text-sm">
    The sooner your teachers complete their first week, the sooner students benefit.
  </p>
</div>

<%# Department aggregate progress bar %>
<% activated   = @teachers.select { |t| t.activation_status == :activated }.count %>
<% in_progress = @teachers.select { |t| t.activation_status == :in_progress }.count %>
<% not_started = @teachers.select { |t| t.activation_status == :not_started }.count %>
<% total_teachers = @teachers.count %>

<div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
  <div class="flex items-center justify-between mb-3">
    <span class="text-sm font-semibold text-gray-700">Department setup</span>
    <span class="text-sm font-bold <%= activated == total_teachers ? 'text-zg-green' : 'text-zg-blue' %>">
      <%= activated %> of <%= total_teachers %> fully set up
    </span>
  </div>
  <div class="w-full bg-gray-100 rounded-full h-3 flex overflow-hidden">
    <div class="h-3 bg-zg-green transition-all duration-500"
         style="width: <%= total_teachers > 0 ? (activated.to_f / total_teachers * 100).round : 0 %>%"></div>
    <div class="h-3 bg-zg-blue transition-all duration-500"
         style="width: <%= total_teachers > 0 ? (in_progress.to_f / total_teachers * 100).round : 0 %>%"></div>
  </div>
  <div class="flex gap-4 mt-2">
    <span class="text-xs text-gray-400 flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-full bg-zg-green"></span><%= activated %> set up</span>
    <span class="text-xs text-gray-400 flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-full bg-zg-blue"></span><%= in_progress %> in progress</span>
    <span class="text-xs text-gray-400 flex items-center gap-1"><span class="inline-block w-2 h-2 rounded-full bg-gray-300"></span><%= not_started %> not started</span>
  </div>
</div>

<%# Teacher table %>
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
    <h2 class="font-semibold text-sm text-gray-700"><%= @department.name %> department</h2>
    <% not_started_names = @teachers.select { |t| t.activation_status == :not_started }.map { |t| t.name.split.first } %>
    <% if not_started_names.any? %>
      <button onclick="nudgeAll(<%= not_started_names.to_json %>)"
              class="text-xs bg-gray-100 text-gray-600 font-medium px-3 py-1.5 rounded-lg hover:bg-gray-200 transition-colors cursor-pointer">
        Nudge all not-started (<%= not_started_names.count %>)
      </button>
    <% end %>
  </div>
  <table class="w-full text-sm">
    <thead>
      <tr class="text-xs font-medium text-gray-400 uppercase tracking-wide bg-gray-50 border-b border-gray-100">
        <th class="px-5 py-3 text-left">Teacher</th>
        <th class="px-5 py-3 text-left">Progress</th>
        <th class="px-5 py-3 text-left">Last active</th>
        <th class="px-5 py-3 text-left">Status</th>
        <th class="px-5 py-3 text-left"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% @teachers.each do |teacher| %>
        <% done       = teacher.tasks_completed_count %>
        <% total      = @total_tasks %>
        <% pct        = total > 0 ? (done.to_f / total * 100).round : 0 %>
        <% days_idle  = teacher.days_since_login %>
        <% is_idle    = teacher.activation_status != :activated && (days_idle.nil? || days_idle > 3) %>
        <% next_task  = @next_task_by_teacher[teacher.id] %>
        <% completed_task_ids = teacher.teacher_task_completions.map(&:onboarding_task_id).to_set %>
        <tr class="hover:bg-gray-50/50 transition-colors cursor-pointer select-none <%= is_idle ? 'border-l-2 border-l-amber-400' : '' %>"
            onclick="toggleTeacherDetails(<%= teacher.id %>)">
          <td class="px-5 py-4">
            <div class="flex items-center gap-2">
              <svg id="chevron-<%= teacher.id %>" class="w-3.5 h-3.5 text-gray-300 transition-transform duration-200 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
              <div>
                <p class="font-medium text-gray-900"><%= teacher.name %></p>
                <p class="text-xs text-gray-400"><%= teacher.email %></p>
              </div>
            </div>
          </td>
          <td class="px-5 py-4">
            <div class="flex items-center gap-2">
              <div class="w-24 bg-gray-100 rounded-full h-1.5">
                <div class="h-1.5 rounded-full <%= pct == 100 ? 'bg-zg-green' : pct > 0 ? 'bg-zg-blue' : 'bg-gray-200' %>"
                     style="width: <%= pct %>%"></div>
              </div>
              <span class="text-xs text-gray-500 whitespace-nowrap"><%= done %>/<%= total %></span>
            </div>
            <% if next_task && teacher.activation_status != :activated %>
              <p class="text-xs text-gray-300 mt-1">On step <%= next_task.position %> · <%= next_task.title %></p>
            <% end %>
          </td>
          <td class="px-5 py-4 text-xs">
            <% if teacher.last_login_at.nil? %>
              <span class="text-gray-300">Never logged in</span>
            <% elsif days_idle == 0 %>
              <span class="text-gray-500">Today</span>
            <% elsif days_idle == 1 %>
              <span class="text-gray-500">Yesterday</span>
            <% else %>
              <span class="<%= is_idle ? 'text-amber-500 font-medium' : 'text-gray-500' %>">
                <%= days_idle %> days ago<%= is_idle ? " ⚠" : "" %>
              </span>
            <% end %>
          </td>
          <td class="px-5 py-4">
            <% case teacher.activation_status %>
            <% when :activated %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">✓ Set up</span>
            <% when :in_progress %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">⬤ In progress</span>
            <% when :not_started %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-600 <%= is_idle ? 'ring-1 ring-amber-300' : '' %>">○ Not started</span>
            <% end %>
          </td>
          <td class="px-5 py-4">
            <% unless teacher.activation_status == :activated %>
              <button onclick="event.stopPropagation(); nudgeTeacher(this, '<%= teacher.name.split.first %>')"
                      class="text-xs text-zg-blue font-medium hover:underline whitespace-nowrap nudge-btn"
                      data-name="<%= teacher.name.split.first %>">
                Send a nudge →
              </button>
            <% end %>
          </td>
        </tr>
        <tr id="teacher-details-<%= teacher.id %>" class="hidden bg-gray-50/70">
          <td colspan="5" class="px-5 py-4">
            <div class="flex gap-8 text-sm">
              <div class="flex-1">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Teacher info</p>
                <dl class="space-y-1">
                  <% if teacher.subject.present? %>
                    <div class="flex gap-2">
                      <dt class="text-gray-400 text-xs w-24 flex-shrink-0">Subject</dt>
                      <dd class="text-gray-700 text-xs"><%= teacher.subject %></dd>
                    </div>
                  <% end %>
                  <% if teacher.topic.present? %>
                    <div class="flex gap-2">
                      <dt class="text-gray-400 text-xs w-24 flex-shrink-0">Topic</dt>
                      <dd class="text-gray-700 text-xs"><%= teacher.topic %></dd>
                    </div>
                  <% end %>
                  <% if teacher.curriculum_level.present? %>
                    <div class="flex gap-2">
                      <dt class="text-gray-400 text-xs w-24 flex-shrink-0">Level</dt>
                      <dd class="text-gray-700 text-xs"><%= teacher.curriculum_level %></dd>
                    </div>
                  <% end %>
                  <div class="flex gap-2">
                    <dt class="text-gray-400 text-xs w-24 flex-shrink-0">Weekly emails</dt>
                    <dd class="text-xs <%= teacher.weekly_email_opted_in ? 'text-green-600' : 'text-gray-400' %>">
                      <%= teacher.weekly_email_opted_in ? "Opted in" : "Not opted in" %>
                    </dd>
                  </div>
                </dl>
              </div>
              <div class="flex-1">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Setup tasks</p>
                <ul class="space-y-1">
                  <% @all_tasks.each do |task| %>
                    <% completed = completed_task_ids.include?(task.id) %>
                    <li class="flex items-start gap-2 text-xs <%= completed ? 'text-gray-400' : 'text-gray-600' %>">
                      <span class="flex-shrink-0 mt-0.5 <%= completed ? 'text-zg-green' : 'text-gray-300' %>">
                        <%= completed ? "✓" : "○" %>
                      </span>
                      <span class="<%= completed ? 'line-through' : '' %>"><%= task.title %></span>
                    </li>
                  <% end %>
                </ul>
              </div>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div id="nudge-toast" class="hidden fixed bottom-6 right-6 bg-gray-900 text-white text-sm px-4 py-3 rounded-xl shadow-lg z-50"></div>

<script>
  function toggleTeacherDetails(id) {
    const row = document.getElementById("teacher-details-" + id);
    const chevron = document.getElementById("chevron-" + id);
    const isOpen = !row.classList.contains("hidden");
    row.classList.toggle("hidden", isOpen);
    chevron.style.transform = isOpen ? "" : "rotate(90deg)";
  }

  function nudgeTeacher(btn, name) {
    btn.textContent = "Sent ✓";
    btn.disabled = true;
    btn.classList.replace("text-zg-blue", "text-gray-400");
    showToast(`Reminder sent to ${name} ✓`);
  }

  function nudgeAll(names) {
    document.querySelectorAll('.nudge-btn').forEach(btn => {
      btn.textContent = "Sent ✓";
      btn.disabled = true;
      btn.classList.replace("text-zg-blue", "text-gray-400");
    });
    const btn = event.currentTarget;
    btn.textContent = "All sent ✓";
    btn.disabled = true;
    showToast(`Reminders sent to ${names.join(", ")} ✓`);
  }

  function showToast(msg) {
    const toast = document.getElementById("nudge-toast");
    toast.textContent = msg;
    toast.classList.remove("hidden");
    setTimeout(() => toast.classList.add("hidden"), 3000);
  }
</script>

<p class="text-xs text-gray-400 mt-4 text-center">
  Nudges send a friendly reminder, not a warning.
</p>
