<div class="mb-8">
  <p class="text-sm text-zg-gray font-medium uppercase tracking-wide mb-1">
    Oakwood Academy · Head of Department
  </p>
  <h1 class="text-2xl font-bold text-gray-900 mb-1">Help your team get set up</h1>
  <p class="text-gray-500 text-sm">
    The sooner your teachers complete their first week, the sooner students benefit.
  </p>
</div>

<%# Summary stat cards %>
<% activated   = @teachers.select { |t| t.activation_status == :activated }.count %>
<% in_progress = @teachers.select { |t| t.activation_status == :in_progress }.count %>
<% not_started = @teachers.select { |t| t.activation_status == :not_started }.count %>

<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-3xl font-bold text-zg-green"><%= activated %></p>
    <p class="text-xs text-gray-500 mt-1 font-medium">Fully set up</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-3xl font-bold text-zg-blue"><%= in_progress %></p>
    <p class="text-xs text-gray-500 mt-1 font-medium">In progress</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
    <p class="text-3xl font-bold text-gray-400"><%= not_started %></p>
    <p class="text-xs text-gray-500 mt-1 font-medium">Not started</p>
  </div>
</div>

<%# Teacher table %>
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100">
    <h2 class="font-semibold text-sm text-gray-700"><%= @department.name %> department</h2>
  </div>
  <table class="w-full text-sm">
    <thead>
      <tr class="text-xs font-medium text-gray-400 uppercase tracking-wide bg-gray-50 border-b border-gray-100">
        <th class="px-5 py-3 text-left">Teacher</th>
        <th class="px-5 py-3 text-left">Progress</th>
        <th class="px-5 py-3 text-left">Last active</th>
        <th class="px-5 py-3 text-left">Status</th>
        <th class="px-5 py-3 text-left"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-50">
      <% @teachers.each do |teacher| %>
        <% done  = teacher.tasks_completed_count %>
        <% total = @total_tasks %>
        <% pct   = total > 0 ? (done.to_f / total * 100).round : 0 %>
        <tr class="hover:bg-gray-50/50 transition-colors">
          <td class="px-5 py-4">
            <p class="font-medium text-gray-900"><%= teacher.name %></p>
            <p class="text-xs text-gray-400"><%= teacher.email %></p>
          </td>
          <td class="px-5 py-4">
            <div class="flex items-center gap-2">
              <div class="w-24 bg-gray-100 rounded-full h-1.5">
                <div class="h-1.5 rounded-full <%= pct == 100 ? 'bg-zg-green' : pct > 0 ? 'bg-zg-blue' : 'bg-gray-200' %>"
                     style="width: <%= pct %>%"></div>
              </div>
              <span class="text-xs text-gray-500 whitespace-nowrap"><%= done %>/<%= total %></span>
            </div>
          </td>
          <td class="px-5 py-4 text-xs text-gray-500">
            <% if teacher.last_login_at.nil? %>
              <span class="text-gray-300">Never logged in</span>
            <% elsif teacher.days_since_login == 0 %>Today
            <% elsif teacher.days_since_login == 1 %>Yesterday
            <% else %><%= teacher.days_since_login %> days ago
            <% end %>
          </td>
          <td class="px-5 py-4">
            <% case teacher.activation_status %>
            <% when :activated %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">✓ Set up</span>
            <% when :in_progress %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">⬤ In progress</span>
            <% when :not_started %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500">○ Not started</span>
            <% end %>
          </td>
          <td class="px-5 py-4">
            <% unless teacher.activation_status == :activated %>
              <button onclick="nudgeTeacher(this, '<%= teacher.name.split.first %>')"
                      class="text-xs text-zg-blue font-medium hover:underline whitespace-nowrap">
                Send a nudge →
              </button>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div id="nudge-toast" class="hidden fixed bottom-6 right-6 bg-gray-900 text-white text-sm px-4 py-3 rounded-xl shadow-lg z-50"></div>

<script>
  function nudgeTeacher(btn, name) {
    btn.textContent = "Sent ✓";
    btn.disabled = true;
    btn.classList.replace("text-zg-blue", "text-gray-400");
    const toast = document.getElementById("nudge-toast");
    toast.textContent = `Reminder sent to ${name} ✓`;
    toast.classList.remove("hidden");
    setTimeout(() => toast.classList.add("hidden"), 3000);
  }
</script>

<p class="text-xs text-gray-400 mt-4 text-center">
  Nudges send a friendly reminder — not a warning. Zero Gravity writes them, not you.
</p>
