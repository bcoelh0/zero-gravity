<turbo-frame id="task_detail">
  <div class="detail-content bg-white rounded-xl border border-gray-200 flex flex-col">
    <div class="px-6 py-4 border-b border-gray-100">
      <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">Task 4 of 5</span>
    </div>
    <div class="px-6 py-6">
      <h2 class="text-lg font-bold text-gray-900 mb-1">Share the AI Tutor with your students</h2>
      <p class="text-sm text-gray-500 mb-6">Send students their join link — takes 2 minutes. Once they're in, you'll see their activity here.</p>

      <div class="mb-2">
        <label class="block text-xs font-medium text-gray-600 mb-1">Your class join link</label>
        <div class="flex items-center gap-2">
          <div class="flex-1 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2.5 text-sm font-mono text-gray-700 truncate">
            join.zerogravity.ai/oak-maths-7b
          </div>
          <button id="copy-btn" onclick="copyAndComplete()" type="button"
                  class="flex-shrink-0 bg-zg-blue text-white text-sm font-semibold px-4 py-2.5 rounded-lg hover:bg-blue-700 transition-colors cursor-pointer">
            Copy link
          </button>
        </div>
      </div>

      <details class="mt-5">
        <summary class="text-xs text-gray-400 hover:text-gray-600 cursor-pointer select-none">
          Suggested message to paste into email or Teams ›
        </summary>
        <div class="mt-3 bg-gray-50 rounded-lg border border-gray-200 p-3 text-xs text-gray-600 leading-relaxed">
          Hi everyone,<br><br>
          We're using Zero Gravity this term to support your revision. Click the link below to get started — it takes under a minute to set up.<br><br>
          <span class="font-mono">join.zerogravity.ai/oak-maths-7b</span><br><br>
          Let me know if you have any questions.
        </div>
      </details>

      <% unless completed %>
        <%= form_with url: task_completions_path, method: :post, id: "copy-complete-form",
                      html: { class: "hidden" } do |f| %>
          <%= hidden_field_tag :teacher_id, teacher.id %>
          <%= hidden_field_tag :onboarding_task_id, task.id %>
        <% end %>
      <% end %>
      <%= render "task_footer", completed: completed, completion_id: completion_id %>
    </div>
  </div>
</turbo-frame>
