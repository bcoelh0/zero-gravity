<turbo-frame id="task_detail">
  <div class="detail-content bg-zg-surface rounded-xl border border-zg-border flex flex-col">
    <div class="px-6 py-4 border-b border-zg-border">
      <span class="text-xs font-medium text-white/40 uppercase tracking-wide">Task 3 of 5</span>
    </div>
    <div class="px-6 py-6">
      <h2 class="text-lg font-bold text-white mb-1">Check a student report</h2>
      <p class="text-sm text-white/50 mb-5">Open any student's report to see where they're strong and where they need support.</p>

      <div class="space-y-2 mb-5">
        <% [
          { name: "Emma Clarke",    initials: "EC", status: "On track",      color: "teal",  last: "Today",
            report: ["Strong on number operations and algebra basics", "Making good progress on quadratic equations", "Could benefit from more practice on graph sketching"] },
          { name: "James Okonkwo",  initials: "JO", status: "Needs support", color: "amber", last: "3 days ago",
            report: ["Struggling with multi-step equations", "Hasn't attempted the last 2 topic quizzes", "Strong on basic arithmetic — build from here"] },
          { name: "Ayesha Patel",   initials: "AP", status: "Excelling",     color: "teal",  last: "Yesterday",
            report: ["Top of class on algebraic reasoning", "Consistently completes extension tasks", "Ready for A-Level stretch material on this topic"] }
        ].each_with_index do |s, i| %>
          <div class="rounded-xl border border-zg-border overflow-hidden">
            <button onclick="toggleReport(<%= i %>)"
                    type="button"
                    class="w-full flex items-center gap-3 px-4 py-3 hover:bg-white/5 transition-colors cursor-pointer text-left">
              <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-xs font-bold text-white/60 flex-shrink-0">
                <%= s[:initials] %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white"><%= s[:name] %></p>
                <p class="text-xs text-white/40">Last active: <%= s[:last] %></p>
              </div>
              <span class="text-xs font-medium px-2 py-1 rounded-full flex-shrink-0
                <%= s[:color] == 'amber' ? 'bg-amber-400/20 text-amber-400' : 'bg-zg-teal/20 text-zg-teal' %>">
                <%= s[:status] %>
              </span>
              <span id="chevron-<%= i %>" class="ml-1 text-white/30 text-xs transition-transform duration-200 flex-shrink-0">▼</span>
            </button>
            <div id="report-<%= i %>" class="hidden px-4 pb-4">
              <ul class="space-y-1.5 mb-3">
                <% s[:report].each do |point| %>
                  <li class="text-xs text-white/60 flex items-start gap-2">
                    <span class="text-white/25 mt-0.5">·</span><span><%= point %></span>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>
      </div>

      <% unless completed %>
        <%= form_with url: task_completions_path, method: :post, id: "got-it-form",
                      html: { class: "hidden" } do |f| %>
          <%= hidden_field_tag :teacher_id, teacher.id %>
          <%= hidden_field_tag :onboarding_task_id, task.id %>
          <button type="submit"
                  class="w-full bg-zg-teal text-zg-bg text-sm font-semibold py-3 px-4 rounded-xl hover:bg-zg-teal/80 transition-colors cursor-pointer">
            Got it →
          </button>
        <% end %>
      <% end %>
      <%= render "tasks/task_footer", completed: completed, completion_id: completion_id %>
    </div>
  </div>
</turbo-frame>
