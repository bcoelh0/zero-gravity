<% footer_message ||= "✓ Completed" %>
<% if completed %>
  <div class="flex items-center justify-between pt-4 mt-2 border-t border-white/10">
    <span class="text-sm font-medium text-zg-teal"><%= footer_message %></span>
    <%= button_to task_completion_path(completion_id),
          method: :delete,
          class: "text-xs text-white/40 hover:text-red-400 transition-colors cursor-pointer underline bg-transparent border-0 p-0",
          form_class: "inline" do %>
      Re-do this task
    <% end %>
  </div>
<% end %>
