<turbo-frame id="task_detail">
  <div class="detail-content bg-zg-surface rounded-xl border border-zg-border flex flex-col">
    <div class="px-6 py-4 border-b border-zg-border">
      <span class="text-xs font-medium text-white/40 uppercase tracking-wide">Task 2 of 5</span>
    </div>
    <div class="px-6 py-6">
      <h2 class="text-lg font-bold text-white mb-1">Assign your first topic</h2>
      <% subject_label = teacher.subject.presence || "Year 10 Maths" %>
      <% level_label   = teacher.curriculum_level.presence %>
      <p class="text-sm text-white/50 mb-6">
        You're teaching <strong class="text-white/80"><%= subject_label %><%= level_label ? " (#{level_label})" : "" %></strong>.
        What are you covering this half-term? The AI tutor will align revision and practice to it.
      </p>

      <% if completed && teacher.topic.present? %>
        <div class="bg-white/5 rounded-xl border border-zg-border p-4 mb-6">
          <p class="text-xs font-medium text-white/40 mb-1">Current topic</p>
          <p class="text-sm font-semibold text-white"><%= teacher.topic %></p>
        </div>
      <% else %>
        <%
          topic_chips = {
            "Mathematics" => ["Quadratic equations", "Trigonometry", "Algebra", "Probability", "Fractions & ratios"],
            "English"     => ["Of Mice and Men", "Macbeth", "An Inspector Calls", "Descriptive writing", "Poetry analysis"],
            "Science"     => ["Forces & motion", "Cell biology", "Chemical reactions", "Electricity", "Genetics"],
            "History"     => ["World War 1", "World War 2", "The Cold War", "Medieval England", "Industrial Revolution"],
            "Geography"   => ["Tectonic hazards", "Urban issues", "River landscapes", "Climate change", "Ecosystems"],
            "Languages"   => ["Present tense verbs", "Holiday vocabulary", "Identity & culture", "Town & directions", "Future plans"],
          }
          chips = topic_chips[teacher.subject] || topic_chips["Mathematics"]
        %>
        <%= form_with url: task_completions_path, method: :post, id: "topic-form" do |f| %>
          <%= hidden_field_tag :teacher_id, teacher.id %>
          <%= hidden_field_tag :onboarding_task_id, task.id %>
          <input type="hidden" name="topic" id="topic-hidden" value="" />
        <% end %>

        <div class="mb-4">
          <label class="block text-xs font-medium text-white/60 mb-1">Topic</label>
          <input id="topic-input" type="text" placeholder="e.g. <%= chips.first %>"
                 oninput="document.getElementById('topic-hidden').value = this.value"
                 class="w-full text-sm border border-zg-border rounded-lg px-3 py-2.5 bg-zg-bg text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-zg-teal" />
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
          <% chips.each do |chip| %>
            <button onclick="document.getElementById('topic-input').value = '<%= chip %>'; document.getElementById('topic-hidden').value = '<%= chip %>'"
                    type="button"
                    class="text-xs px-3 py-1.5 rounded-full border border-zg-border text-white/60 hover:border-zg-teal hover:text-zg-teal transition-colors cursor-pointer bg-zg-bg">
              <%= chip %>
            </button>
          <% end %>
        </div>

        <button onclick="document.getElementById('topic-form').requestSubmit()"
                type="button"
                class="w-full bg-zg-teal text-zg-bg text-sm font-semibold py-3 px-4 rounded-xl hover:bg-zg-teal/80 transition-colors cursor-pointer">
          Set topic →
        </button>
      <% end %>

      <%= render "tasks/task_footer", completed: completed, completion_id: completion_id %>
    </div>
  </div>
</turbo-frame>
