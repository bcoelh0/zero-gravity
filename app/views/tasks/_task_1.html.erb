<turbo-frame id="task_detail">
  <div class="detail-content bg-zg-surface rounded-xl border border-zg-border flex flex-col">
    <div class="px-6 py-4 border-b border-zg-border">
      <span class="text-xs font-medium text-white/40 uppercase tracking-wide">Task 1 of 5</span>
    </div>
    <div class="px-6 py-6">
      <h2 class="text-lg font-bold text-white mb-1">Set up your first class</h2>
      <p class="text-sm text-white/50 mb-6">Your classes are already imported. Just confirm the subject and level so the AI tutor knows what to focus on.</p>

      <% if completed && teacher.subject.present? %>
        <div class="bg-white/5 rounded-xl border border-zg-border p-4 mb-6">
          <p class="text-xs font-semibold text-white/40 uppercase tracking-wide mb-3">Year 10 Set 2</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <p class="text-xs font-medium text-white/40 mb-1">Subject</p>
              <p class="text-sm font-semibold text-white"><%= teacher.subject %></p>
            </div>
            <div>
              <p class="text-xs font-medium text-white/40 mb-1">Curriculum level</p>
              <p class="text-sm font-semibold text-white"><%= teacher.curriculum_level %></p>
            </div>
          </div>
        </div>
      <% else %>
        <%= form_with url: task_completions_path, method: :post, id: "setup-form" do |f| %>
          <%= hidden_field_tag :teacher_id, teacher.id %>
          <%= hidden_field_tag :onboarding_task_id, task.id %>

          <div class="bg-white/5 rounded-xl border border-zg-border p-4 mb-6">
            <p class="text-xs font-semibold text-white/40 uppercase tracking-wide mb-3">Year 10 Set 2</p>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-medium text-white/60 mb-1">Subject</label>
                <select name="subject"
                        class="w-full text-sm border border-zg-border rounded-lg px-3 py-2 bg-zg-bg text-white focus:outline-none focus:ring-2 focus:ring-zg-teal">
                  <% %w[Mathematics English Science History Geography Languages Other].each do |s| %>
                    <option <%= "selected" if teacher.subject == s %>><%= s %></option>
                  <% end %>
                </select>
              </div>
              <div>
                <label class="block text-xs font-medium text-white/60 mb-1">Curriculum level</label>
                <select name="curriculum_level"
                        class="w-full text-sm border border-zg-border rounded-lg px-3 py-2 bg-zg-bg text-white focus:outline-none focus:ring-2 focus:ring-zg-teal">
                  <% %w[GCSE KS3 A-Level].each do |l| %>
                    <option <%= "selected" if teacher.curriculum_level == l %>><%= l %></option>
                  <% end %>
                </select>
              </div>
            </div>
          </div>

          <button type="submit"
                  class="w-full bg-zg-teal text-zg-bg text-sm font-semibold py-3 px-4 rounded-xl hover:bg-zg-teal/80 transition-colors cursor-pointer">
            Confirm setup →
          </button>
        <% end %>
      <% end %>

      <%= render "tasks/task_footer", completed: completed, completion_id: completion_id %>
    </div>
  </div>
</turbo-frame>
