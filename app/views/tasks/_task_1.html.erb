<turbo-frame id="task_detail">
  <div class="detail-content bg-white rounded-xl border border-gray-200 flex flex-col">
    <div class="px-6 py-4 border-b border-gray-100">
      <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">Task 1 of 5</span>
    </div>
    <div class="px-6 py-6">
      <h2 class="text-lg font-bold text-gray-900 mb-1">Set up your first class</h2>
      <p class="text-sm text-gray-500 mb-6">Your classes are already imported. Just confirm the subject and level so the AI tutor knows what to focus on.</p>

      <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 mb-6">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Year 10 Set 2</p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Subject</label>
            <select class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-zg-blue">
              <option>Mathematics</option>
              <option>English</option>
              <option>Science</option>
              <option>History</option>
              <option>Geography</option>
              <option>Languages</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Curriculum level</label>
            <select class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-zg-blue">
              <option>GCSE</option>
              <option>KS3</option>
              <option>A-Level</option>
            </select>
          </div>
        </div>
      </div>

      <% unless completed %>
        <%= button_to task_completions_path,
              params: { teacher_id: teacher.id, onboarding_task_id: task.id },
              method: :post,
              class: "w-full bg-zg-blue text-white text-sm font-semibold py-3 px-4 rounded-xl hover:bg-blue-700 transition-colors cursor-pointer" do %>
          Confirm setup →
        <% end %>
      <% end %>
      <%= render "task_footer", completed: completed, completion_id: completion_id %>
    </div>
  </div>
</turbo-frame>
